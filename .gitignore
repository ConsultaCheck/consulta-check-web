# ===========================================
# ConsultaCheck Web - Gitignore
# ===========================================

# Dependencias
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
/.next/
/out/

# Build de producción
/build

# Variables de entorno (NUNCA subir credenciales ni URLs sensibles)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Mantener .env.example como plantilla (no ignorar)

# Vercel
.vercel

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
/coverage

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Sistema operativo
.DS_Store
.DS_Store?
._*
Thumbs.db

# IDE / Editores
.idea/
.vscode/
*.swp
*.swo
*~

# Certificados (nunca subir)
*.pem

# Temporal y cache
.temp/
tmp/
.cache/
